#!/bin/bash

# cscs-cl-v2 — Connect to CSCS login nodes using a service account
#
# Adaptation of the ML community's cscs-cl script. Instead of
# username + password + OTP, it uses a service account API Key
# to obtain an OIDC token and generate an ephemeral SSH key (1min),
# then immediately connects to the target host.
#
# Note: Service accounts currently only support ephemeral keys (1min).
# The key expires 60 seconds after generation — the script generates
# a fresh key on every invocation.
#
# Usage:
#   ./cscs-cl-v2 [command]
#
# Environment variables:
#   CSCS_SERVICE_ACCOUNT_API_KEY  — Your service account API Key (required)
#   HPC_USER_BASE_URL             — hpc-user API (default: https://api-service-account.hpc-user.svc.cscs.ch)
#   HPC_SSH_BASE_URL              — hpc-ssh API (default: https://api-ssh-service.hpc-ssh.svc.cscs.ch)
#
# Prerequisites:
#   - curl and jq must be installed
#   - A service account created on portal.cscs.ch (Waldur)

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
HPC_USER_BASE_URL="${HPC_USER_BASE_URL:-https://api-service-account.hpc-user.svc.cscs.ch}"
HPC_SSH_BASE_URL="${HPC_SSH_BASE_URL:-https://api-ssh-service.hpc-ssh.svc.cscs.ch}"

TOKEN_ENDPOINT="${HPC_USER_BASE_URL}/api/v1/auth/token"
GENERATE_ENDPOINT="${HPC_SSH_BASE_URL}/api/v1/ssh-keys"

SSH_KEY_PATH="$HOME/.ssh/cscs-key"
SSH_CERT_PATH="$HOME/.ssh/cscs-key-cert.pub"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
die() {
    echo "Error: $*" >&2
    exit 1
}

check_dependencies() {
    command -v curl >/dev/null 2>&1 || die "curl is required but not installed."
    command -v jq >/dev/null 2>&1 || die "jq is required but not installed."
}

# Function to setup SSH config if it doesn't exist
setup_ssh_config() {
    local username="$1"
    local ssh_config="$HOME/.ssh/config"

    mkdir -p "$HOME/.ssh"
    touch "$ssh_config"

    # Check if config already has clariden entry
    if grep -q "Host clariden" "$ssh_config" 2>/dev/null; then
        return
    fi

    cat >> "$ssh_config" << EOF

Host ela ela.cscs.ch
    Hostname ela.cscs.ch
    User ${username}
    ForwardAgent yes
    ForwardX11 yes
    ForwardX11Trusted yes
    StrictHostKeyChecking accept-new
    IdentityFile ~/.ssh/cscs-key

Host clariden clariden.cscs.ch
    Hostname clariden.cscs.ch
    User ${username}
    ForwardAgent yes
    StrictHostKeyChecking accept-new
    IdentityFile ~/.ssh/cscs-key
    ProxyJump ela
EOF
    echo "  SSH config updated for ela and clariden."
}

# ---------------------------------------------------------------------------
# Step 1: Exchange API Key for OIDC Access Token
# ---------------------------------------------------------------------------
get_access_token() {
    local api_key="$1"

    echo "  Requesting access token ..."

    local response
    response=$(curl -s -w "\n%{http_code}" -X POST \
        "${TOKEN_ENDPOINT}" \
        -H "X-API-Key: ${api_key}")

    local http_code
    http_code=$(echo "$response" | tail -1)
    local body
    body=$(echo "$response" | sed '$d')

    case "$http_code" in
        201) ;;
        401) die "Invalid API Key. Check your service account credentials." ;;
        403) die "Service account is disabled or inactive." ;;
        404) die "Service account not found." ;;
        *)   die "Token request failed (HTTP ${http_code}): ${body}" ;;
    esac

    ACCESS_TOKEN=$(echo "$body" | jq -r '.access_token // empty')
    [ -n "$ACCESS_TOKEN" ] || die "No access_token in response: ${body}"

    local expires_in
    expires_in=$(echo "$body" | jq -r '.expires_in // "unknown"')
    echo "  Access token obtained (expires in ${expires_in}s)"
}

# ---------------------------------------------------------------------------
# Step 2: Generate SSH Key
# ---------------------------------------------------------------------------
generate_ssh_key() {
    local access_token="$1"
    local duration="${2:-1d}"

    echo "  Generating SSH key (duration=${duration}) ..."

    local response
    response=$(curl -s -w "\n%{http_code}" -X POST \
        "${GENERATE_ENDPOINT}" \
        -H "Authorization: Bearer ${access_token}" \
        -H "Content-Type: application/json" \
        -d "{\"duration\": \"${duration}\"}")

    local http_code
    http_code=$(echo "$response" | tail -1)
    local body
    body=$(echo "$response" | sed '$d')

    case "$http_code" in
        201) ;;
        401) die "Access token is invalid or expired." ;;
        *)   die "Key generation failed (HTTP ${http_code}): ${body}" ;;
    esac

    # Extract keys from JSON response
    PUBLIC_KEY=$(echo "$body" | jq -r '.sshKey.publicKey // empty')
    PRIVATE_KEY=$(echo "$body" | jq -r '.sshKey.privateKey // empty')
    SERIAL_NUMBER=$(echo "$body" | jq -r '.sshKey.serialNumber // "N/A"')
    EXPIRE_TIME=$(echo "$body" | jq -r '.sshKey.expireTime // "N/A"')

    [ -n "$PUBLIC_KEY" ] || die "No publicKey in response"
    [ -n "$PRIVATE_KEY" ] || die "No privateKey in response"

    echo "  Key generated (serial: ${SERIAL_NUMBER}, expires: ${EXPIRE_TIME})"
    echo "  WARNING: Key expires in 60 seconds — connecting immediately."
}

# ---------------------------------------------------------------------------
# Step 3: Write keys
# ---------------------------------------------------------------------------
write_keys() {
    echo "  Writing keys to ${SSH_KEY_PATH} ..."

    mkdir -p "$HOME/.ssh"

    # Write private key
    printf '%s\n' "$PRIVATE_KEY" > "$SSH_KEY_PATH"
    chmod 600 "$SSH_KEY_PATH"

    # Write certificate
    printf '%s\n' "$PUBLIC_KEY" > "$SSH_CERT_PATH"
    chmod 644 "$SSH_CERT_PATH"

    echo "  Keys written successfully."
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    check_dependencies

    # Parse arguments
    if [[ "${1:-}" == "--help" ]]; then
        cat << EOF
Usage: $(basename "$0") [command]

Connect to CSCS Clariden using a service account for SSH key generation.

Options:
  --help      Show this help message

Environment:
  CSCS_SERVICE_ACCOUNT_API_KEY    Your service account API Key (required)
  HPC_USER_BASE_URL               hpc-user API URL (optional)
  HPC_SSH_BASE_URL                hpc-ssh API URL (optional)

The script will:
  1. Exchange your API Key for an OIDC access token
  2. Generate an ephemeral SSH key (expires in 60 seconds)
  3. Write keys to ~/.ssh/cscs-key
  4. Connect to Clariden immediately

Because keys are ephemeral (1min), a fresh key is generated on every run.
EOF
        exit 0
    fi

    # Validate API Key
    local api_key="${CSCS_SERVICE_ACCOUNT_API_KEY:-}"
    if [ -z "$api_key" ]; then
        echo "CSCS_SERVICE_ACCOUNT_API_KEY is not set."
        echo ""
        echo "To use this script, you need a service account API Key from portal.cscs.ch."
        echo "Set it as an environment variable:"
        echo ""
        echo '  export CSCS_SERVICE_ACCOUNT_API_KEY="your-api-key-here"'
        echo ""
        exit 1
    fi

    echo "CSCS SSH Key Setup (Service Account — ephemeral 1min key)"
    echo "========================================================="
    echo ""

    # Step 1: Get access token
    echo "[1/3] Authenticating ..."
    get_access_token "$api_key"
    echo ""

    # Step 2: Generate key (always 1min for service accounts)
    echo "[2/3] Generating ephemeral SSH key ..."
    generate_ssh_key "$ACCESS_TOKEN" "1min"
    echo ""

    # Step 3: Write keys
    echo "[3/3] Installing keys ..."
    write_keys
    echo ""

    # Setup SSH config (detects username from the certificate)
    local username
    username=$(ssh-keygen -L -f "$SSH_CERT_PATH" 2>/dev/null | grep "Principals:" -A1 | tail -1 | tr -d ' ' || true)
    if [ -n "$username" ]; then
        setup_ssh_config "$username"
    fi

    echo "Connecting to Clariden (key expires in ~60s) ..."

    # Build environment variables (if user.env exists)
    local env_vars=""
    local user_env=""  # Set to your user.env path if needed

    if [ -f "$user_env" ]; then
        while IFS='=' read -r key value || [ -n "$key" ]; do
            [[ -z "$key" || "$key" =~ ^# ]] && continue
            value=$(echo "$value" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e 's/^"//' -e 's/"$//')
            if [ -n "$value" ]; then
                [ -z "$env_vars" ] && env_vars="export " || env_vars+=" "
                env_vars+="${key}=${value}"
            fi
        done < "$user_env"
    fi

    # Connect: interactive shell or run command
    local tty_flag=""
    [ $# -eq 0 ] && tty_flag=" -t"

    ssh${tty_flag} clariden "${env_vars:+$env_vars; }${@:-exec \$SHELL -l}"
}

main "$@"
